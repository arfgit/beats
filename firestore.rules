rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isProjectMember(project) {
      return request.auth != null && (
        project.ownerId == request.auth.uid
        || project.isPublic == true
        || request.auth.uid in project.collaboratorIds
      );
    }

    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    // Users: self-read only. Public profile fields go through the BFF,
    // which strips email and gates on isPublic.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Projects: owner / collaborator / public.
    match /projects/{projectId} {
      // Public projects readable by anyone (gallery browsing while signed-out).
      // Private projects readable only to owner or named collaborators.
      allow read: if resource.data.isPublic == true
                  || (request.auth != null
                      && (resource.data.ownerId == request.auth.uid
                          || request.auth.uid in resource.data.collaboratorIds));
      allow write: if false;

      // Presence: only project members can see others; each writer can only
      // touch their own presence doc.
      match /presence/{uid} {
        allow read: if isProjectMember(projectData(projectId));
        allow write: if request.auth != null
                     && uid == request.auth.uid
                     && isProjectMember(projectData(projectId));
      }
    }

    match /uploadedTracks/{trackId} {
      allow read: if request.auth != null
                  && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }

    match /samples/{sampleId} {
      allow read: if resource.data.isBuiltIn == true
                  || (request.auth != null && resource.data.ownerId == request.auth.uid);
      allow write: if false;
    }

    // Per-user upload quota counter. Server writes only — the doc tracks
    // how many custom samples a user has and their total bytes, used to
    // gate POST /api/samples/upload-url before issuing a signed URL.
    match /userQuotas/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /invites/{inviteId} {
      allow read, write: if false;
    }

    // Reverse lookup: code → uid. Any authed user can read because the
    // whole point is paste-to-connect. Mitigations live at the API
    // layer: rate-limited code submission, plus the keyspace itself
    // (~28^5 = 17M codes) bounds enumeration. Server writes via Admin
    // SDK on code generation + rotation.
    match /buddyCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user buddy graph. Both sides written atomically by the
    // server on accept; only the owning uid can read their own list.
    match /users/{uid}/buddies/{otherUid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Pending buddy requests (both incoming + outgoing live here,
    // distinguished by the `direction` field). Mirrored on both
    // users' subcollections with the same id for symmetric ops.
    match /users/{uid}/buddyRequests/{requestId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
