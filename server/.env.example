# Local dev
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# CORS allowlist (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# Firebase project
FIREBASE_PROJECT_ID=beats-prod-ant
GCLOUD_PROJECT=beats-prod-ant

# Admin credentials — pick ONE path:
# Option A — point at a local service account JSON (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=./beats-prod-ant-serviceAccountKey.json
#
# Option B — paste the service account JSON as a single env var
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
#
# Option C (default here) — leave blank and run against emulators:
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
