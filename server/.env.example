# Local dev
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# CORS allowlist (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# Firebase project
FIREBASE_PROJECT_ID=beats-prod-ant
GCLOUD_PROJECT=beats-prod-ant

# Admin credentials. Default is "talk to production Firebase using ADC"
# (run `gcloud auth application-default login` once). Override only if you
# need a specific service account JSON.
#
# Option A — point at a local service account JSON (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=./beats-prod-ant-serviceAccountKey.json
#
# Option B — paste the service account JSON as a single env var
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Firebase emulator hosts — UNCOMMENT ONLY when you're actually running
# `firebase emulators:start` in another terminal. If these are set but the
# emulator isn't running (or worse: the client is hitting prod), the admin
# SDK routes token verification through the emulator and rejects every
# production-signed Google ID token with `invalid signature`.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
