    "firebase-functions": "^6.1.1",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.9",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
