{
  "name": "@beats/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/functions.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
