# Firebase Web SDK config — find these in Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=beats-dev-ant.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=beats-dev-ant
VITE_FIREBASE_STORAGE_BUCKET=beats-dev-ant.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# local dev
VITE_USE_EMULATORS=true
VITE_API_BASE=/api
