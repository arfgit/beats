# Firebase Web SDK config — find these in Firebase Console → Project Settings → Your apps
# (Settings gear → General → scroll to "Your apps" → Web app → Config)
#
# NOTE on "VITE_FIREBASE_API_KEY": Firebase Web API keys are public
# identifiers, not secrets — they're meant to be shipped in the browser
# bundle. Real access control lives in firestore.rules + storage.rules
# (in this repo) and optional Firebase App Check. Still, do NOT commit
# your project's actual key to .env.example — GitHub secret scanners
# flag any Google API key pattern. Each dev/clone fills their own
# .env.local with the values from their Firebase Console.
# See https://firebase.google.com/docs/projects/api-keys
VITE_FIREBASE_API_KEY=your-web-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
# Realtime Database — used for live collab session state. Default
# region is `*-default-rtdb.firebaseio.com`; override only if your
# database lives in europe-west1 / asia-southeast1 / etc.
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Set to "true" only when you're also running `npm run emulators` in a
# second terminal. Otherwise keep "false" to hit production Firestore +
# Storage + Auth directly. Production is the default for solo dev since
# it removes the need to keep emulators running + re-seeded.
VITE_USE_EMULATORS=false
VITE_API_BASE=/api

# Debug only: force every sample URL to this literal instead of fetching
# from Firebase Storage. Useful for isolating Tone.js graph issues from
# Storage fetch/CORS issues. Leave blank for normal operation.
# VITE_AUDIO_HARDWIRE_URL=https://tonejs.github.io/audio/drum-samples/4OP-FM/kick.mp3
