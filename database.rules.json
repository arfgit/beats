{
  "rules": {
    "users": {
      "$uid": {
        "online": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        },
        "incomingInvites": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": false,
          "$inviteId": {
            // Recipient can delete (mark consumed) but cannot create or
            // overwrite. `!newData.exists()` says "the after-state is
            // empty," i.e. this is a delete. Writes (newData.exists())
            // stay server-only via Admin SDK. Without this, the client
            // dbRemove() lands in a Firebase optimistic-write loop:
            // local cache flips to gone, onValue re-fires, server
            // rejects the delete, cache reverts, onValue re-fires
            // again, handler retries the delete, infinite toasts.
            ".write": "auth != null && auth.uid == $uid && !newData.exists()"
          }
        },
        "inviteEvents": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": false,
          "$eventId": {
            // Same recipient-can-delete-but-not-write contract as above.
            ".write": "auth != null && auth.uid == $uid && !newData.exists()"
          }
        }
      }
    },
    "sessions": {
      "$sessionId": {
        ".read": "auth != null && root.child('sessions').child($sessionId).child('meta').exists()",
        ".write": false,

        "meta": {
          ".write": false
        },

        "state": {
          ".write": "auth != null && root.child('sessions').child($sessionId).child('meta').child('ownerUid').val() == auth.uid"
        },

        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid && root.child('sessions').child($sessionId).child('meta').exists()"
          }
        },

        "edits": {
          "$editId": {
            ".write": "auth != null && root.child('sessions').child($sessionId).child('participants').child(auth.uid).exists() && (!data.exists() || newData.child('peerId').val() == auth.uid)",
            ".validate": "newData.hasChildren(['peerId', 'op', 'clientTs']) && newData.child('peerId').val() == auth.uid"
          }
        },

        "presence": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid && root.child('sessions').child($sessionId).child('participants').child(auth.uid).exists()"
          }
        }
      }
    }
  }
}
